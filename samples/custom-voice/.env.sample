# Custom Voice sample configuration
# Copy this file to .env and fill in your values.
# The .env file is ignored by git so your secrets are safe.

# ===================== Required =====================

# Speech resource key. Get it from "Keys and Endpoint" tab on your Speech resource in Azure Portal.
SPEECH_KEY=

# Speech resource region. E.g., eastus, westeurope, southeastasia, westus2, eastasia
SPEECH_REGION=eastus

# ===================== Professional Voice only =====================

# Local folder containing training audio (.wav) and script (.txt) files.
# Sample data: https://github.com/Azure-Samples/Cognitive-Speech-TTS/tree/master/CustomVoice/Sample%20Data
TRAINING_DATA_FOLDER=

# Azure Blob Storage account name (e.g., "mystorageaccount")
BLOB_ACCOUNT_NAME=

# Azure Blob Storage account URL (e.g., "https://mystorageaccount.blob.core.windows.net")
BLOB_ACCOUNT_URL=

# Azure Blob Storage account key
BLOB_ACCOUNT_KEY=

# Azure Blob Storage container name (default: voicedata)
# BLOB_CONTAINER_NAME=voicedata

# ===================== Optional =====================

# Voice consent audio file path (default: TestData/VoiceTalentVerbalStatement.wav)
# CONSENT_FILE_PATH=TestData/VoiceTalentVerbalStatement.wav

# Personal voice audio folder (default: TestData/voice)
# AUDIO_FOLDER=TestData/voice

# Voice talent name (default: Sample Voice Actor)
# VOICE_TALENT_NAME=Sample Voice Actor

# Company name (default: Contoso)
# COMPANY_NAME=Contoso

# Locale for voice resources (default: en-us)
# LOCALE=en-us

# Voice name for professional voice model (default: SampleVoiceNeural)
# VOICE_NAME=SampleVoiceNeural

# Recipe kind for professional voice model (default: Default)
# RECIPE_KIND=Default

# ===================== Optional: resource IDs (defaults are fine) =====================

# PERSONAL_PROJECT_ID=personal-voice-project-1
# PERSONAL_CONSENT_ID=personal-voice-consent-1
# PERSONAL_VOICE_ID=personal-voice-1

# PROFESSIONAL_PROJECT_ID=professional-voice-project-1
# PROFESSIONAL_CONSENT_ID=professional-voice-consent-1
# PROFESSIONAL_TRAINING_SET_ID=professional-voice-trainingset-1
# PROFESSIONAL_MODEL_ID=professional-voice-model-1
